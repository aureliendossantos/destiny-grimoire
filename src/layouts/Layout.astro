---
import Footer, { type FooterProps } from "$components/Layout/Footer.astro"
import FooterFallback from "$components/Layout/FooterFallback.astro"
import Header from "$components/Layout/Header.astro"
import Seo from "$components/Layout/Seo.astro"
import { getLocaleFromPathname, htmlLang } from "$utils/i18n"
import type { StructuredData } from "$utils/seo"
import "$styles/tailwind.css"
import "$styles/fonts.css"
// Supports weights 400-800
import "@fontsource-variable/eb-garamond/wght.css"
import "@fontsource-variable/eb-garamond/wght-italic.css"

type Props = {
	title: string
	description: string
	contentHeightScreen?: boolean
	noindex?: boolean
	structuredData?: StructuredData | StructuredData[]
} & FooterProps
const {
	title,
	description,
	contentHeightScreen,
	noindex,
	structuredData,
	...footerProps
} = Astro.props
const pathname = Astro.url.pathname
const locale = getLocaleFromPathname(pathname) || "en"
---

<!doctype html>
<html lang={htmlLang(locale)}>
	<head>
		<meta charset="UTF-8" />
		<Seo {title} {description} {noindex} {structuredData} />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<meta name="theme-color" content="#e2e8f0" />
		<link rel="preconnect" href="https://rsms.me/" />
		<link rel="stylesheet" href="https://rsms.me/inter/inter.css" />
	</head>
	<body class="bg-slate-50 font-sans text-slate-950">
		<div class="flex min-h-screen flex-col justify-between">
			<div
				class:list={{
					"flex min-h-screen flex-col": contentHeightScreen,
				}}
			>
				<Header />
				<slot />
			</div>
			<Footer server:defer {locale} {pathname} {...footerProps}>
				<FooterFallback slot="fallback" />
			</Footer>
		</div>
	</body>
</html>
