---
import { getImage } from "astro:assets"
import { getCardImage } from "$utils/card-images"
import { membershipTypeToPath } from "$utils/helpers"
import {
	getLocaleFromPathname,
	getLocalizedPath,
	useTranslations,
} from "$utils/i18n"
import { getStaticImage } from "$utils/static-images"
import type { CollectionEntry } from "astro:content"

interface Props {
	card: CollectionEntry<"cards">["data"][string]
	membershipType?: 1 | 2
	username?: string
	isObscured?: boolean
	useStaticImages?: boolean
}

const {
	card,
	membershipType,
	username,
	isObscured = false,
	useStaticImages = false,
} = Astro.props
const locale = getLocaleFromPathname(Astro.url.pathname) || "en"
const t = useTranslations(locale)
const cardImage = getCardImage(card.cardId, card.highResolution.image.sheetPath)
const image = useStaticImages
	? getStaticImage({
			src: cardImage,
			alt: t("card-illustration-alt"),
			width: 320,
		})
	: await getImage({
			src: cardImage,
			alt: t("card-illustration-alt"),
			width: 320,
		})
const { class: _className, ...imageAttributes } = image.attributes
---

<a
	href={getLocalizedPath(
		locale,
		membershipType && username
			? `/user/${membershipTypeToPath(membershipType)}/${username}/${card.cardId}`
			: `/${card.cardId}`,
	)}
	data-spoiler-hidden={isObscured ? "" : undefined}
	hidden={isObscured}
	class="relative flex aspect-card flex-col justify-end overflow-hidden rounded-sm px-3 py-3 shadow transition duration-300 ease-out hover:scale-105 hover:shadow-xl sm:px-4 md:px-5 md:py-[17px]"
	class:list={{
		"opacity-60 grayscale hover:opacity-100 hover:grayscale-0": isObscured,
	}}
>
	<img
		src={image.src}
		{...imageAttributes}
		class="absolute inset-0 h-full w-full bg-slate-400 object-cover"
	/>
	<h3
		class="z-10 text-xs font-semibold text-balance text-slate-100 sm:text-sm lg:text-base lg:leading-snug"
		style={{ textShadow: "0 0 0.1em #000" }}
		set:html={card.cardName}
	/>
</a>
