---
import { deconstructUrl } from "$utils/helpers"
import {
	getLocaleFromPathname,
	getLocalizedPath,
	localeNames,
	localeParams,
	stripLocaleFromPathname,
	useTranslations,
} from "$utils/i18n"
import HeaderLink from "$components/Layout/HeaderLink.astro"

const locale = getLocaleFromPathname(Astro.url.pathname) || "en"
const t = useTranslations(locale)
const pathname = stripLocaleFromPathname(Astro.url.pathname)
const { platform, username, rest } = deconstructUrl(pathname)
const basePath = platform ? `/user/${platform}/${username}` : ``
const sectionPath = platform ? rest || "/" : pathname
const activeSection = sectionPath.startsWith("/tracker")
	? "tracker"
	: sectionPath === "/all" ||
		  /^\d+$/.test(sectionPath.slice(1)) ||
		  (platform && sectionPath === "/")
		? "grimoire"
		: sectionPath.startsWith("/books")
			? "books"
			: sectionPath === "/about"
				? "about"
				: undefined
---

<header class="bg-slate-200 pl-4 sm:px-8">
	<div class="m-auto flex min-h-17 flex-wrap items-center gap-x-4">
		<a
			href={getLocalizedPath(locale, "/")}
			class="inline-flex items-center gap-2 pt-4 pr-4 font-accent text-xl leading-none tracking-[0.08em] text-slate-500 uppercase transition hover:text-slate-400 md:pb-4"
		>
			<span>The Grimoire Archive</span>
			<span
				class="inline-flex h-5 w-5 items-center justify-center rounded-full bg-amber-100 text-amber-700 ring-1 ring-amber-300"
				title="Service notice"
			>
				<span class="sr-only">Service notice</span>
				<svg
					xmlns="http://www.w3.org/2000/svg"
					viewBox="0 0 24 24"
					fill="none"
					stroke="currentColor"
					stroke-linecap="round"
					stroke-linejoin="round"
					stroke-width="2.5"
					class="h-3.5 w-3.5"
					aria-hidden="true"
				>
					<path
						d="m21.73 18-8-14a2 2 0 0 0-3.46 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3"
					></path>
					<path d="M12 9v4"></path>
					<path d="M12 17h.01"></path>
				</svg>
			</span>
		</a>
		<div class="grow"></div>
		<div
			class="group -mx-2 flex max-w-full flex-wrap items-center py-4 text-sm font-medium text-slate-500 md:mx-0"
		>
			<HeaderLink
				id="header-grimoire-link"
				href={getLocalizedPath(locale, platform ? basePath : "/all")}
				isActive={activeSection === "grimoire"}
			>
				{t("Grimoire")}
			</HeaderLink>
			<HeaderLink
				id="header-tracker-link"
				href={getLocalizedPath(locale, `${basePath}/tracker`)}
				isActive={activeSection === "tracker"}
			>
				{t("Tracker")}
			</HeaderLink>
			<HeaderLink
				href={getLocalizedPath(locale, "/books")}
				isActive={activeSection === "books"}
			>
				{t("Books")}
			</HeaderLink>
			<form
				action={getLocalizedPath(locale, "/search")}
				method="get"
				class="pl-[10px]"
			>
				<label
					class="flex cursor-pointer items-center overflow-hidden rounded-lg ring-slate-300 transition has-[:focus]:bg-slate-50 has-[:focus]:ring"
				>
					<input
						type="search"
						name="term"
						class="peer w-0 border-y-0 bg-slate-50 py-2 font-sans text-sm font-medium text-slate-600 placeholder:text-slate-400 focus:w-[138px] focus:pl-3 focus:transition-all focus:outline-none"
						placeholder={t("Search")}
					/>
					<svg
						xmlns="http://www.w3.org/2000/svg"
						width="32"
						height="32"
						viewBox="0 0 24 24"
						class="mr-2 h-[1lh] w-[1lh] text-slate-500 hover:text-slate-400"
						><path
							fill="currentColor"
							d="M15.5 14h-.79l-.28-.27A6.47 6.47 0 0 0 16 9.5A6.5 6.5 0 1 0 9.5 16c1.61 0 3.09-.59 4.23-1.57l.27.28v.79l5 4.99L20.49 19zm-6 0C7.01 14 5 11.99 5 9.5S7.01 5 9.5 5S14 7.01 14 9.5S11.99 14 9.5 14"
						></path></svg
					>
				</label>
			</form>
			<select
				id="header-language-switcher"
				class="rounded-lg bg-transparent py-2 pl-1 ring-slate-300 transition hover:bg-slate-100 hover:ring-1 sm:pl-3"
			>
				{
					localeParams.map((localePath) => {
						return (
							<option
								value={getLocalizedPath(localePath, pathname)}
								data-locale={localePath}
								selected={localePath == locale}
							>
								{localeNames[localePath]}
							</option>
						)
					})
				}
			</select>
		</div>
	</div>
</header>

<script>
	import Cookies from "js-cookie"
	import { validateCookie } from "$utils/helpers"

	document
		.getElementById("header-language-switcher")
		?.addEventListener("change", (t) => {
			if (!(t.currentTarget instanceof HTMLSelectElement)) return
			const locale = t.currentTarget.selectedOptions[0]?.dataset.locale
			if (locale) Cookies.set("userLocale", locale, { path: "/" })
			window.location.pathname = t.currentTarget.value
		})

	const tryCookie = Cookies.get("grimoireLogin")
	const loginCookie = tryCookie && validateCookie(JSON.parse(tryCookie))

	if (loginCookie) {
		const platform = loginCookie.membershipType == 1 ? "xbox" : "psn"
		const username = loginCookie.username
		const grimoireLink = document.getElementById("header-grimoire-link")
		const trackerLink = document.getElementById("header-tracker-link")

		grimoireLink?.setAttribute("href", `/user/${platform}/${username}`)
		trackerLink?.setAttribute(
			"href",
			`/user/${platform}/${username}/tracker`,
		)
	}
</script>
