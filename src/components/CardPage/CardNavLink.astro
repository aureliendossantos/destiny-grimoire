---
import { getImage } from "astro:assets"
import { getCardImage } from "$utils/card-images"
import { membershipTypeToPath } from "$utils/helpers"
import {
	getLocaleFromPathname,
	getLocalizedPath,
	useTranslations,
} from "$utils/i18n"
import { getStaticImage } from "$utils/static-images"
import type { CollectionEntry } from "astro:content"

interface Props {
	card: CollectionEntry<"cards">["data"][string]
	themeTitle?: string
	next?: boolean
	isObscured?: boolean
	user?: {
		membershipType: 1 | 2
		name: string
	}
	useStaticImages?: boolean
}

const {
	card,
	themeTitle,
	next,
	user,
	isObscured = false,
	useStaticImages = false,
} = Astro.props
const locale = getLocaleFromPathname(Astro.url.pathname) || "en"
const t = useTranslations(locale)
const cardImage = getCardImage(card.cardId, card.highResolution.image.sheetPath)
const image = useStaticImages
	? getStaticImage({
			src: cardImage,
			alt: t("card-illustration-alt"),
			height: 128,
		})
	: await getImage({
			src: cardImage,
			alt: t("card-illustration-alt"),
			height: 128,
		})
const { class: _className, ...imageAttributes } = image.attributes
---

<a
	href={getLocalizedPath(
		locale,
		user
			? `/user/${membershipTypeToPath(user.membershipType)}/${user.name}/${card.cardId}`
			: `/${card.cardId}`,
	)}
	class:list={[
		"flex items-center gap-4 leading-snug",
		{
			"col-start-2 flex-row-reverse text-right": next,
			"opacity-60 grayscale": isObscured,
		},
	]}
>
	<img
		src={image.src}
		{...imageAttributes}
		class="h-16 w-auto rounded-[1.5px] bg-slate-400 shadow-sm"
	/>
	<div>
		{
			themeTitle && (
				<div class="font-smcp text-slate-400" set:html={themeTitle} />
			)
		}
		<div class="text-balance" set:html={card.cardName} />
	</div>
</a>
