---
export const prerender = false

import Layout from "$layouts/Layout.astro"
import SubHeader from "$components/Layout/SubHeader.astro"
import {
	BungieApiError,
	getMembershipId,
	membershipTypeToPath,
} from "$utils/helpers"
import { getLocalizedPath, getRouteLocale } from "$utils/i18n"

const locale = getRouteLocale(Astro.params.locale)
if (!locale) return new Response("Not found", { status: 404 })

const homePath = getLocalizedPath(locale, "/")
if (!homePath.startsWith("/")) throw new Error("Invalid locale home path")
if (Astro.request.method != "POST") return Astro.redirect(homePath, 308)

// POST request must include parameters "platform", "username", and optionally a redirect path
const formData = await Astro.request.formData()
const platform = formData.get("platform")
const username = formData.get("username")
const redirect = formData.get("redirect")
const redirectPath = typeof redirect == "string" ? redirect : ""

if (typeof username != "string") return Astro.redirect(homePath)

// platform: "true" is 1 (xbox), "false" is 2 (psn)
const membershipType = platform ? 1 : 2
let membershipId: string | null = null
let apiError: BungieApiError | null = null

try {
	membershipId = await getMembershipId(membershipType, username)
} catch (error) {
	if (error instanceof BungieApiError) {
		apiError = error
	} else {
		throw error
	}
}

const errorMessage = apiError
	? `Bungie API error (${apiError.status}, code ${apiError.code}): ${apiError.message}`
	: !membershipId &&
		`Could not find a Bungie account with ${platform ? "Xbox" : "PSN"} username "${username}". Please check that the username is correct and that you have played Destiny 1 on this platform.`

if (membershipId) {
	Astro.cookies.set(
		"grimoireLogin",
		{
			membershipType: membershipType,
			membershipId: membershipId,
			username: username,
		},
		{ path: "/" },
	)
	const userPath = getLocalizedPath(
		locale,
		`/user/${membershipTypeToPath(membershipType)}/${username}${redirectPath}`,
	)
	if (!userPath.startsWith("/")) throw new Error("Invalid user redirect path")
	return Astro.redirect(userPath)
}
---

<Layout
	title="Destiny Grimoire Login Error · The Grimoire Archive"
	description="Bungie account not found for Destiny Grimoire collection login."
	noindex
>
	<SubHeader title="Connection failed" subtitle="Bungie account not found." />
	<div class="flex h-96 items-center justify-center">
		<div class="max-w-md rounded-md bg-slate-200 p-8">
			{errorMessage}
		</div>
	</div>
</Layout>
