---
import Layout from "$layouts/Layout.astro"
import TrackerIndex from "$components/Tracker/TrackerIndex.astro"
import {
	checkLocale,
	getLocalizedPath,
	localizedRouteParams,
} from "$utils/i18n"
import { getCollectionPageStructuredData } from "$utils/seo"

export async function getStaticPaths() {
	return localizedRouteParams.map((localePath) => {
		const locale = checkLocale(localePath)
		return {
			params: { locale: localePath },
			props: { locale },
		}
	})
}
const { locale } = Astro.props
const title = "Destiny 1 Grimoire Tracker · The Grimoire Archive"
const description =
	"Track Destiny 1 Grimoire Cards, hidden dead ghosts, bonus progress, and collectible locations with guide pages."
const structuredData = getCollectionPageStructuredData({
	name: title,
	description,
	url: new URL(getLocalizedPath(locale, "/tracker"), Astro.site || Astro.url),
})
---

<Layout {title} {description} {structuredData} onGrimoirePage>
	<TrackerIndex {locale} />
</Layout>
<div id="locale" data-locale={locale}></div>

<script>
	import Cookies from "js-cookie"
	import { validateCookie } from "$utils/helpers"

	// get the cookie grimoireLogin
	const tryCookie = Cookies.get("grimoireLogin")
	const loginCookie = tryCookie && validateCookie(JSON.parse(tryCookie))

	if (loginCookie) {
		// find tracker links and add the user to the path
		const links = document.querySelectorAll(
			`a[data-nav-card="tracker"]`,
		) as NodeListOf<HTMLAnchorElement>
		const platform = loginCookie.membershipType == 1 ? "xbox" : "psn"
		const username = loginCookie.username

		links.forEach((link) => {
			const href = link.getAttribute("href")
			const userPath = `/user/${platform}/${username}/tracker`
			link.setAttribute("href", href!.replace("/tracker", userPath))
		})
	}
</script>
