---
import TrackerPage from "$components/Tracker/TrackerPage.astro"
import Layout from "$layouts/Layout.astro"
import { getGuides } from "$utils/content"
import { checkLocale, localizedRouteParams } from "$utils/i18n"

export async function getStaticPaths() {
	return (
		await Promise.all(
			localizedRouteParams.flatMap(async (localePath) => {
				const locale = checkLocale(localePath)
				const guides = await getGuides(locale)
				return guides.types.map((guide) => ({
					params: { locale: localePath, guide: guide.slug },
					props: {
						guide,
						locale,
					},
				}))
			}),
		)
	).flat()
}
const { guide, locale } = Astro.props
---

<Layout
	title={`${guide.name} · Destiny 1 Tracker · The Grimoire Archive`}
	description=""
	onGrimoirePage
>
	<TrackerPage {locale} guideSlug={guide.slug} />
</Layout>
