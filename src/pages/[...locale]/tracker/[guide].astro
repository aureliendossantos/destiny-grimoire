---
import TrackerPage from "$components/Tracker/TrackerPage.astro"
import Layout from "$layouts/Layout.astro"
import { getGuides } from "$utils/content"
import { checkLocale, localizedRouteParams } from "$utils/i18n"

export async function getStaticPaths() {
	return (
		await Promise.all(
			localizedRouteParams.flatMap(async (localePath) => {
				const locale = checkLocale(localePath)
				const guides = await getGuides(locale)
				return guides.types.map((guide) => ({
					params: { locale: localePath, guide: guide.slug },
					props: {
						guide,
						locale,
					},
				}))
			}),
		)
	).flat()
}
const { guide, locale } = Astro.props
const guideItemCount = guide.areas.reduce(
	(total, area) => total + area.items.length,
	0,
)
const description = `Find all ${guideItemCount} ${guide.name} entries for Destiny 1 Grimoire Cards with area-by-area tracker guidance.`
---

<Layout
	title={`${guide.name} · Destiny 1 Grimoire Tracker · The Grimoire Archive`}
	{description}
	onGrimoireHomePage
>
	<TrackerPage {locale} guideSlug={guide.slug} />
</Layout>
