---
export const prerender = false

import { getLocalizedPath, getRouteLocale } from "$utils/i18n"

const locale = getRouteLocale(Astro.params.locale)
if (!locale) return new Response("Not found", { status: 404 })

const redirect = Astro.url.searchParams.get("redirect")

Astro.cookies.delete("grimoireLogin", { path: "/" })
const redirectPath = getLocalizedPath(locale, redirect || "/")
if (!redirectPath.startsWith("/"))
	throw new Error("Invalid logout redirect path")
return new Response(null, {
	status: 302,
	headers: {
		Location: redirectPath,
		"X-Robots-Tag": "noindex, nofollow",
	},
})
---
