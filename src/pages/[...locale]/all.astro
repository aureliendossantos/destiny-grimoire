---
import Layout from "$layouts/Layout.astro"
import Grimoire from "$components/Grimoire/Grimoire.astro"
import {
	checkLocale,
	getLocalizedPath,
	localizedRouteParams,
	useTranslations,
} from "$utils/i18n"
import { getCards, getThemes } from "$utils/content"
import SubHeader from "$components/Layout/SubHeader.astro"
import { getCollectionPageStructuredData } from "$utils/seo"

export async function getStaticPaths() {
	return await Promise.all(
		localizedRouteParams.map(async (localePath) => {
			const locale = checkLocale(localePath)
			const themes = await getThemes(locale)
			const cards = await getCards(locale)
			return {
				params: { locale: localePath },
				props: {
					cards,
					themes,
					locale,
					t: useTranslations(locale),
				},
			}
		}),
	)
}

const { cards, themes, locale, t } = Astro.props
const title = "Destiny Grimoire Cards Collection · The Grimoire Archive"
const description =
	"Browse every Destiny Grimoire Card by theme, lore category, and card name in The Grimoire Archive."
const structuredData = getCollectionPageStructuredData({
	name: title,
	description,
	url: new URL(getLocalizedPath(locale, "/all"), Astro.site || Astro.url),
})
---

<Layout {title} {description} {structuredData} onGrimoirePage>
	<SubHeader title={t("grimoire-cards")}>
		<Fragment slot="subtitle">
			{`${t("global-data")} `}
			<a
				class="font-medium underline"
				href={getLocalizedPath(locale, "/")}>{t("g-Login")}</a
			>
			{t("g-to see yours")}
		</Fragment>
	</SubHeader>
	<div class="mr-2 ml-10 sm:mr-4">
		<div class="m-auto mt-10 mb-12 max-w-6xl">
			<Grimoire {themes} {cards} />
		</div>
	</div>
</Layout>
