---
export const prerender = false

import Layout from "$layouts/Layout.astro"
import {
	getMembershipId,
	getUserGrimoire,
	getUserSummary,
} from "$utils/helpers"
import { getRouteLocale, useTranslations } from "$utils/i18n"

const routeLocale = getRouteLocale(Astro.params.locale)
if (!routeLocale) return new Response("Not found", { status: 404 })
const { platform, username } = Astro.params
if ((platform != "psn" && platform != "xbox") || !username)
	return new Response("Not found", { status: 404 })
const t = useTranslations(routeLocale)
const membershipType = platform == "xbox" ? 1 : 2
const membershipId = await getMembershipId(membershipType, username!)
if (!membershipId) return new Response("Not found", { status: 404 })

const userGrimoire = await getUserGrimoire(membershipType, membershipId)
if (!userGrimoire) return new Response("Not found", { status: 404 })

const summary = await getUserSummary(membershipType, membershipId)
const bestCharacter = summary.characters.sort(
	(a: any, b: any) => b.characterBase.powerLevel - a.characterBase.powerLevel,
)[0]
---

<Layout
	title={`${username} Destiny Fireteam · The Grimoire Archive`}
	description={`${username}'s Destiny character and Grimoire collection summary.`}
	noindex
>
	<div class="m-12">
		<div class="relative flex h-[48px]">
			<img src={`https://www.bungie.net${bestCharacter.emblemPath}`} />
			<img
				src={`https://www.bungie.net${bestCharacter.backgroundPath}`}
			/>
			<div
				class="absolute top-0 left-12 flex h-full flex-col justify-center px-2 text-base leading-tight font-semibold text-slate-50 drop-shadow"
			>
				<div>{username}</div>
				<div class="pb-[1px] text-xs font-semibold">
					{userGrimoire.cardCollection.length}
					{t("cards")} // {userGrimoire.score}
					{t("points")}
				</div>
			</div>
		</div>
	</div>
</Layout>
