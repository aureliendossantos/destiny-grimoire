---
export const prerender = false

import Layout from "$layouts/Layout.astro"
import { getCards, getThemes } from "$utils/content"
import {
	getMembershipId,
	getUserGrimoire,
	parseParamsWithUser,
} from "$utils/helpers"
import Grimoire from "$components/Grimoire/Grimoire.astro"
import { useTranslations } from "$utils/i18n"
import SubHeader from "$components/Layout/SubHeader.astro"

const { locale, platform, username } = parseParamsWithUser(Astro.params)
if (!locale) return new Response("Not found", { status: 404 })

const t = useTranslations(locale)
const themes = await getThemes(locale)
const cards = await getCards(locale)

if ((platform != "psn" && platform != "xbox") || !username)
	return new Response("Not found", { status: 404 })
const membershipType = platform == "xbox" ? 1 : 2
const membershipId = await getMembershipId(membershipType, username)
if (!membershipId) return new Response("Not found", { status: 404 })

const userGrimoire = await getUserGrimoire(membershipType, membershipId)
if (!userGrimoire) return new Response("Not found", { status: 404 })
---

<Layout
	title={`${username} · Destiny Grimoire Cards · The Grimoire Archive`}
	description={`${userGrimoire.cardCollection.length} ${t("cards")} // ${userGrimoire.score} ${t("points")}`}
	noindex
	onGrimoireHomePage
	userInPath={{
		membershipType,
		membershipId,
		name: username,
	}}
>
	<SubHeader title={t("grimoire-cards")}>
		<div slot="subtitle">
			<div>
				{t("g-Collection of")}
				<img
					class="hidden h-[1em] w-[1em] rounded-sm bg-slate-300 align-[-10%]"
					alt=""
					data-current-user-icon
					data-membership-id={membershipId}
				/>
				{username} // {userGrimoire.cardCollection.length}
				{t("cards")} // {userGrimoire.score}
				{t("points")}
			</div>
			<label
				class="mt-1 flex cursor-pointer items-center gap-2 text-slate-500"
			>
				<input
					id="show-unobtained-cards"
					type="checkbox"
					data-spoiler-toggle
					class="h-3 w-3 accent-slate-600"
				/>
				<span>{t("show-unobtained-cards")}</span>
			</label>
		</div>
	</SubHeader>
	<div class="mr-2 ml-10 sm:mr-4">
		<div class="m-auto mt-10 mb-12 max-w-6xl">
			<Grimoire
				{themes}
				{cards}
				{userGrimoire}
				{membershipType}
				{username}
				useStaticImages
			/>
		</div>
	</div>
</Layout>

<script is:inline>
	;(() => {
		const getCookie = (name) => {
			const prefix = `${name}=`
			const value = document.cookie
				.split("; ")
				.find((part) => part.startsWith(prefix))
				?.slice(prefix.length)
			if (!value) return null

			try {
				return decodeURIComponent(value)
			} catch {
				return value
			}
		}

		let cookie = null
		try {
			cookie = JSON.parse(getCookie("grimoireLogin"))
		} catch {
			cookie = null
		}
		if (
			!cookie ||
			typeof cookie.membershipId !== "string" ||
			typeof cookie.emblemPath !== "string" ||
			!cookie.emblemPath.startsWith("/")
		) {
			return
		}

		for (const icon of document.querySelectorAll(
			"[data-current-user-icon]",
		)) {
			if (
				icon instanceof HTMLImageElement &&
				icon.dataset.membershipId === cookie.membershipId
			) {
				icon.src = `https://www.bungie.net${cookie.emblemPath}`
				icon.classList.remove("hidden")
				icon.classList.add("inline-block")
			}
		}
	})()
</script>
