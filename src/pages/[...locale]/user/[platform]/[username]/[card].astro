---
export const prerender = false

import Layout from "$layouts/Layout.astro"
import { getCards, getThemes } from "$utils/content"
import {
	getMembershipId,
	getUserGrimoire,
	parseParamsWithUser,
} from "$utils/helpers"
import CardPage from "$components/CardPage/CardPage.astro"
import { useTranslations } from "$utils/i18n"
import { fetchCardImageManifest } from "$utils/card-image-manifest"

const { locale, platform, username, cardId } = parseParamsWithUser(Astro.params)
if (!locale) return new Response("Not found", { status: 404 })

const t = useTranslations(locale)
const themes = await getThemes(locale)
const cards = await getCards(locale)
const card = cards[cardId!]

if ((platform != "psn" && platform != "xbox") || !card)
	return new Response("Not found", { status: 404 })
const membershipType = platform == "xbox" ? 1 : 2
const membershipId = await getMembershipId(membershipType, username)
if (!membershipId) return new Response("Not found", { status: 404 })

const userGrimoire = await getUserGrimoire(membershipType, membershipId)
if (!userGrimoire) return new Response("Not found", { status: 404 })

const userCard = userGrimoire.cardCollection.find(
	(c) => c.cardId == card.cardId,
)
// It's safe to assume there is only one bonus per card (I checked)
const userBonus = userGrimoire.bonuses.find((b) => b.cardId == card.cardId)

// Reuse the statically-built card image instead of the on-demand `/_image`
// endpoint (which always cache-misses on Vercel). Degrade gracefully to
// `<Image>` if the manifest can't be fetched.
const image = await fetchCardImageManifest(Astro.url.origin)
	.then((manifest) => manifest[card.cardId]?.page)
	.catch(() => undefined)
---

<Layout
	title={`${card.cardName} · Destiny Grimoire Card · The Grimoire Archive`}
	description={card.cardIntro || card.cardDescription || ""}
	noindex
	userInPath={{ membershipType, membershipId, name: username }}
	contentHeightScreen
	onGrimoireCardPage
>
	<CardPage
		{t}
		{card}
		{cards}
		{themes}
		{image}
		user={{
			card: userCard,
			bonus: userBonus,
			membershipType,
			membershipId,
			name: username,
			grimoire: userGrimoire,
		}}
	/>
</Layout>
