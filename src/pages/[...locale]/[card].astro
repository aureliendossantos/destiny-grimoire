---
import Layout from "$layouts/Layout.astro"
import CardPage from "$components/CardPage/CardPage.astro"
import { getCards, getThemes } from "$utils/content"
import {
	checkLocale,
	getLocalizedPath,
	localizedRouteParams,
	useTranslations,
} from "$utils/i18n"
import { getBreadcrumbListStructuredData } from "$utils/seo"

export async function getStaticPaths() {
	return (
		await Promise.all(
			localizedRouteParams.flatMap(async (localePath) => {
				const locale = checkLocale(localePath)
				const themes = await getThemes(locale)
				const cards = await getCards(locale)
				return Object.values(cards).map((card) => ({
					params: { locale: localePath, card: String(card.cardId) },
					props: {
						card,
						cards,
						locale,
						themes,
						t: useTranslations(locale),
					},
				}))
			}),
		)
	).flat()
}
const { card, cards, locale, themes, t } = Astro.props
const structuredData = getBreadcrumbListStructuredData([
	{
		name: "Destiny Grimoire Cards",
		url: new URL(getLocalizedPath(locale, "/all"), Astro.site || Astro.url),
	},
	{
		name: card.cardName,
		url: new URL(
			getLocalizedPath(locale, `/${card.cardId}`),
			Astro.site || Astro.url,
		),
	},
])
---

<Layout
	title={`${card.cardName} · Destiny Grimoire Card · The Grimoire Archive`}
	description={card.cardIntro || card.cardDescription || ""}
	{structuredData}
	contentHeightScreen
	onGrimoireSection
>
	<CardPage {t} {card} {cards} {themes} />
</Layout>
